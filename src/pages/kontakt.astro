---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Kontakt"
  description="Kontakt TorgBar for spørsmål, booking eller samarbeid."
>
  <section class="max-w-2xl mx-auto px-6 py-24">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-black mb-4">Kontakt oss</h1>
      <p class="text-muted">Har du spørsmål? Vi hjelper deg gjerne.</p>
    </div>

    <div class="space-y-8">
      <div class="bg-white border border-warm-gray rounded-2xl p-8">
        <h3 class="font-bold mb-2">E-post</h3>
        <a href="mailto:elvickongolo@gmail.com" class="text-amber hover:underline">elvickongolo@gmail.com</a>
      </div>

      <div class="bg-white border border-warm-gray rounded-2xl p-8">
        <h3 class="font-bold mb-2">Lokasjon</h3>
        <p class="text-muted">Vi leverer i hele Norge. Hovedbase: Tromsø.</p>
      </div>

      <div class="bg-white border border-warm-gray rounded-2xl p-8">
        <h3 class="font-bold mb-4">Eller bare book direkte</h3>
        <a href="/booking" class="inline-block bg-amber text-dark px-6 py-3 rounded-full font-semibold text-sm hover:bg-amber-light transition-colors">
          Gå til booking
        </a>
      </div>
    </div>
  </section>
</Layout>
