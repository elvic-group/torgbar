---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontakt" description="Kontakt TorgBar for spørsmål, booking eller samarbeid.">
  <section class="bg-light py-24 lg:py-32">
    <div class="max-w-2xl mx-auto px-6">
      <div class="mb-12">
        <h1 class="font-display text-5xl md:text-7xl text-dark leading-none">KONTAKT<br /><span class="text-primary">OSS</span></h1>
      </div>
      <div class="space-y-6">
        <div class="bg-dark border border-border rounded-2xl p-8">
          <h3 class="font-display text-xl text-light mb-2 tracking-wide">E-post</h3>
          <a href="mailto:elvickongolo@gmail.com" class="text-primary hover:underline">elvickongolo@gmail.com</a>
        </div>
        <div class="bg-dark border border-border rounded-2xl p-8">
          <h3 class="font-display text-xl text-light mb-2 tracking-wide">Lokasjon</h3>
          <p class="text-light/50">Hovedbase: Tromsø. Vi leverer i hele Norge.</p>
        </div>
        <div class="bg-dark border border-border rounded-2xl p-8 text-center">
          <a href="/booking" class="inline-block bg-primary text-light px-8 py-3 rounded-full font-semibold hover:bg-primary/80 transition-all duration-200">GÅ TIL BOOKING</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
