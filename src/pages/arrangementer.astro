---
import Layout from "../layouts/Layout.astro";

const events = [
  { name: "TORGBAR FESTIVAL", desc: "Skreddersydd for festivaler og store publikumsarrangementer. Full selvbetjeningsbar." },
  { name: "TORGBAR BEDRIFT", desc: "Imponer kunder og kollegaer med en unik bedriftsfest." },
  { name: "TORGBAR PRIVAT", desc: "Gjør bryllupet, bursdagen eller hagenfesten uforglemmelig." },
  { name: "TORGBAR BRYGGERI", desc: "Ditt bryggeri får en mobil taproom. Lanseringer og tap takeovers." },
  { name: "TORGBAR EVENT", desc: "Fleksibel løsning for messer, konserter og markeder." },
];
const locations = ["TROMSØ", "FREDRIKSTAD", "LOFOTEN", "SORTLAND", "OSLO"];
---

<Layout title="Arrangementer" description="TorgBar leverer til alle typer arrangementer i Norge.">
  <section class="bg-light py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16">
        <span class="text-primary font-bold text-xs uppercase tracking-[0.2em]">Arrangementer</span>
        <h1 class="font-display text-5xl md:text-7xl text-dark mt-4 leading-none">VI LEVERER<br /><span class="text-primary">TIL HELE NORGE</span></h1>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
        {events.map((ev) => (
          <div class="bg-dark border border-border rounded-2xl p-8 hover:border-primary transition-colors">
            <h3 class="font-display text-2xl text-light mb-2 tracking-wide">{ev.name}</h3>
            <p class="text-light/50 text-sm leading-relaxed">{ev.desc}</p>
          </div>
        ))}
      </div>
      <h2 class="font-display text-3xl text-dark text-center mb-8 tracking-wide">LOKASJONER</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 max-w-3xl mx-auto">
        {locations.map((loc) => (
          <div class="bg-dark rounded-2xl p-6 text-center hover:bg-primary transition-colors duration-300">
            <p class="font-display text-xl text-light">{loc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
