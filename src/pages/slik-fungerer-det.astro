---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Slik fungerer det" description="Slik fungerer TorgBar — fra booking til servering.">
  <section class="bg-light py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="mb-16">
        <span class="text-accent font-bold text-xs uppercase tracking-[0.2em]">Prosessen</span>
        <h1 class="font-display text-5xl md:text-7xl text-dark mt-4 leading-none">SLIK FUNGERER<br /><span class="text-primary">DET</span></h1>
      </div>
      <div class="space-y-16">
        {[
          { num: "01", title: "BOOK DIN PAKKE", text: "Velg pakken som passer ditt arrangement — Festival, Bedrift, Privat, Bryggeri eller Event. Fortell oss om dato, sted og antall gjester. Vi bekrefter tilgjengelighet og gir deg et tilbud." },
          { num: "02", title: "VI FORBEREDER ALT", text: "Vi håndterer all logistikk — transport, rigging, tappesystem, ølbestilling, bemanning og merkevareprofilering. Du trenger ikke løfte en finger." },
          { num: "03", title: "TRAILEREN ANKOMMER", text: "På arrangementsdagen kommer vi med traileren i god tid. Vi rigger opp, kobler til, og sørger for at alt er klart før første gjest." },
          { num: "04", title: "SELVBETJENING", text: "Gjestene tapper øl selv fra vårt intuitive tappesystem. Vårt personale er til stede for å hjelpe og sørge for ansvarlig servering." },
          { num: "05", title: "VI RYDDER OG DRAR", text: "Når arrangementet er over, tar vi ned alt, rydder opp og kjører traileren bort. Du sitter igjen med bare gode minner." },
        ].map((step) => (
          <div class="flex gap-8 items-start">
            <div class="w-16 h-16 bg-dark rounded-2xl flex items-center justify-center shrink-0">
              <span class="font-display text-2xl text-primary">{step.num}</span>
            </div>
            <div>
              <h3 class="font-display text-2xl text-dark mb-2 tracking-wide">{step.title}</h3>
              <p class="text-muted leading-relaxed">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
