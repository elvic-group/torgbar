---
import Layout from "../layouts/Layout.astro";

const packages = ["FESTIVAL", "BEDRIFT", "PRIVAT", "BRYGGERI", "EVENT"];
---

<Layout
  title="Booking"
  description="Book TorgBar til ditt neste arrangement. Velg pakke, dato og sted."
>
  <section class="bg-light py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16">
        <span class="text-primary font-bold text-xs uppercase tracking-[0.2em]">Booking</span>
        <h1 class="font-display text-5xl md:text-7xl text-dark mt-4 leading-none">BOOK<br /><span class="text-primary">TORGBAR</span></h1>
        <p class="text-muted mt-4 max-w-lg">Velg en pakke og finn en tid som passer. Vi tar kontakt for å bekrefte detaljene.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-10 max-w-5xl mx-auto">
        <div class="lg:col-span-1 space-y-3">
          <h3 class="font-display text-2xl text-dark mb-4 tracking-wide">Velg pakke</h3>
          {packages.map((pkg) => (
            <button class="w-full text-left p-4 rounded-xl border border-border hover:border-primary hover:bg-primary/5 transition-all group bg-dark text-light">
              <span class="font-bold text-sm">{pkg}</span>
              <p class="text-xs text-muted mt-1">Etter avtale</p>
            </button>
          ))}
        </div>

        <div class="lg:col-span-2 bg-dark border border-border rounded-2xl overflow-hidden">
          <div class="calendly-inline-widget" data-url="https://calendly.com/elvickongolo" style="min-width:320px;height:700px;"></div>
          <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" is:inline></script>
        </div>
      </div>

      <div class="max-w-xl mx-auto mt-16 p-8 bg-dark border border-border rounded-2xl text-center">
        <h3 class="font-display text-2xl text-light mb-2 tracking-wide">Direkte kontakt</h3>
        <p class="text-muted text-sm mb-4">Send oss en e-post, så finner vi en løsning sammen.</p>
        <a href="mailto:elvickongolo@gmail.com" class="inline-block bg-primary text-light px-6 py-3 rounded-full font-semibold text-sm hover:bg-primary/80 transition-all duration-200">
          SEND E-POST
        </a>
      </div>
    </div>
  </section>
</Layout>
